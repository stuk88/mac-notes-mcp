{
  "name": "@kolivri/mac-notes-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets Claude Code read, search, and edit Apple Notes on macOS.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mac-notes-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --test --import tsx test/integration.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "apple-notes",
    "macos",
    "notes"
  ],
  "author": "stas@kolivri.com",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
